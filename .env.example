# ╔═══════════════════════════════════════════════════════════╗
# ║          TAM PERSONAL ASSISTANT v2.0 - .env               ║
# ║         Environment Variables Template                    ║
# ╚═══════════════════════════════════════════════════════════╝
#
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace EACH placeholder with YOUR actual values
# 3. Do NOT commit .env to Git (add to .gitignore)
# 4. Restart bot after changing: npm start

# ════════════════════════════════════════════════════════════
# ⚠️  REQUIRED - Bot WILL NOT START without these!
# ════════════════════════════════════════════════════════════

# Your WhatsApp number with country code (NO + or spaces)
# Examples: 923001234567 (Pakistan), 918765432100 (India), 14155552671 (USA)
# Get this from your WhatsApp profile
OWNER_NUMBER=923001234567

# Alert recipient number (can be same as OWNER_NUMBER)
# This number receives keyword alerts and important notifications
ALERT_NUMBER=923001234567

# Groq API Key (FREE at https://console.groq.com)
# 1. Go to https://console.groq.com
# 2. Click "API Keys" in left sidebar
# 3. Click "Create API Key"
# 4. Copy the key that starts with "gsk_"
# 5. Paste below (DO NOT share this key!)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════════
# ⚠️  RECOMMENDED - Data won't survive restarts without this
# ════════════════════════════════════════════════════════════

# GitHub Token for cloud data backup (FREE)
# Needed for: reminders, notes, bans, stats surviving restarts
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token (classic)"
# 3. Name it: "tam-assistant"
# 4. Check ONLY the "gist" checkbox
# 5. Click "Generate Token"
# 6. Copy immediately (you won't see it again!)
# 7. Paste below
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════════
# 🟢 OPTIONAL - Leave blank to skip
# ════════════════════════════════════════════════════════════

# WhatsApp Session ID (for skipping QR scan on restarts)
# Get from bot logs: "[AUTH] Session found with ID: ..."
# Leave blank to scan QR code on first run
SESSION_ID=

# Gist ID for data storage (auto-created if blank)
# You don't need to set this - bot creates it automatically
GIST_ID=

# OCR API key for text extraction from images (FREE at ocr.space)
# Fallback when Groq Vision isn't available
# Leave blank to skip OCR features
OCR_API_KEY=

# Server port (default: 3000)
# Change if port 3000 is already in use
PORT=3000

# Logging level: 'warn' (normal) or 'debug' (verbose for debugging)
LOG_LEVEL=warn

# Node.js version for Render (if deploying there)
NODE_VERSION=18

# ════════════════════════════════════════════════════════════
# 📝 NOTES
# ════════════════════════════════════════════════════════════
# 
# 1. NEVER commit this file to Git - use .env.example instead
# 2. Phone numbers MUST include country code (no + symbol)
#    - Pakistan: 92 → 923001234567
#    - India: 91 → 918765432100
#    - USA: 1 → 14155552671
#
# 3. API Keys are secret - NEVER share them or commit them
#    - Each key should be unique to this bot
#    - Rotate them periodically for security
#
# 4. For deployment (Render/Replit), add these same variables
#    to your service's Environment Variables settings
#
# 5. Minimum working .env has just 4 lines:
#    OWNER_NUMBER=923001234567
#    ALERT_NUMBER=923001234567
#    GROQ_API_KEY=gsk_...
#    (That's it! Optional fields can be added later)
