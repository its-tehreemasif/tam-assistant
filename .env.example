# OpenClaw / TAM Assistant v2.0 — Environment Variables
# Add ALL of these to your Render service → Environment tab

# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key (console.groq.com — free)
GROQ_API_KEY=gsk_...

# WhatsApp session Base64 string (leave blank to scan QR on first run)
SESSION_ID=

# ── Recommended ───────────────────────────────────────────────────────────────

# GitHub Personal Access Token — needed for cloud persistence (no memory loss on restart)
# Create at: github.com → Settings → Developer Settings → Personal Access Tokens → Classic
# Required scope: gist (check only "gist" scope)
GITHUB_TOKEN=ghp_...

# ── Optional ──────────────────────────────────────────────────────────────────

# OCR.space API key — fallback if Groq Vision fails (ocr.space — free)
OCR_API_KEY=

# Owner WhatsApp number (international format, no + or spaces)
OWNER_NUMBER=923344440964

# Alert number (receives keyword alerts)
ALERT_NUMBER=923175867622

# Node version for Render
NODE_VERSION=18
